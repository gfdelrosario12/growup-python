# GrowUp IoT System - Environment Configuration

# ===========================
# BACKEND CONFIGURATION
# ===========================
# Local Spring Boot backend URL
BACKEND_URL=http://localhost:8080

# Sensor readings endpoint (auto-constructed from BACKEND_URL if not set)
SENSOR_READINGS_ENDPOINT=http://localhost:8080/api/sensor-readings

# Plant growth endpoint
PLANT_GROWTH_ENDPOINT=http://localhost:8080/api/plant-growth

# ML results endpoint (camera detections)
ML_RESULTS_ENDPOINT=http://localhost:8080/api/ml-results

# Request timeout in seconds
REQUEST_TIMEOUT=10

# Sensor send interval in seconds (1 = every second)
SEND_INTERVAL=1

# Device identifier
DEVICE_ID=pi-001

# ===========================
# LOGGING
# ===========================
# Verbose logging (true/false)
VERBOSE_LOGGING=true

# ===========================
# CAMERA CONFIGURATION
# ===========================
# WebSocket server host (0.0.0.0 for all interfaces)
CAM_WS_HOST=0.0.0.0

# WebSocket server port
CAM_WS_PORT=8765

# Camera device index (0 = default)
CAM_INDEX=0

# YOLO model path (yolov8n.pt = nano, use custom path for trained models)
CAM_MODEL_PATH=yolov8n.pt

# Send base64 JPEG frames to WebSocket clients (true/false)
# Note: Set to false to reduce bandwidth on Pi
CAM_SEND_FRAMES=false

# Frame scale factor (0.5 = 50% size, reduces inference load)
CAM_FRAME_SCALE=0.5

# Camera capture FPS
CAM_CAPTURE_FPS=5

# Send ML results to backend /api/ml-results (true/false)
SEND_ML_RESULTS=true

# ===========================
# MQTT CONFIGURATION
# ===========================
# MQTT broker address (host:port)
MQTT_BROKER=localhost:1883

# MQTT topic for camera detections
MQTT_DETECTIONS_TOPIC=camera/detections

# ===========================
# CONTROL CONFIGURATION
# ===========================
# MQTT topic for device control commands
# Format: growup/device/{DEVICE_ID}/control
# Messages: action:value (e.g., "pump:on", "light:80")
